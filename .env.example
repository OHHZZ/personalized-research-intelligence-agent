# Optional future integrations.
# Set to true to use the LangGraph state-machine pipeline with parallel connectors
# and conditional routing (fallback to sample on live failure, supervisor-based routing).
USE_LANGGRAPH_PIPELINE=false
ENABLE_LLM_ANALYSIS=false
LLM_MODEL=qwen-plus
LLM_ANALYSIS_LIMIT=10
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GITHUB_TOKEN=
GITHUB_API_VERSION=2022-11-28
RESEARCH_INTEL_USER_AGENT=PersonalizedResearchIntelligenceAgent/0.1
SEMANTIC_SCHOLAR_API_KEY=
CONNECTOR_TIMEOUT_SECONDS=8
LIVE_MAX_QUERIES_PER_SOURCE=3
ARXIV_REQUEST_DELAY_SECONDS=3
ARXIV_RESULTS_PER_QUERY=8
SEMANTIC_SCHOLAR_REQUEST_DELAY_SECONDS=1
OPENALEX_MAX_QUERIES=3
OPENALEX_RESULTS_PER_QUERY=8
OPENALEX_SORT=relevance_score:desc
OPENALEX_MAILTO=
# Optional. Set these if your machine needs an HTTP proxy for Python requests.
# Leave blank to clear inherited broken proxy values.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
GIT_HTTP_PROXY=
GIT_HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1
RAG_EMBEDDING_DIM=384
RAG_TOP_K=8
EMBEDDING_PROVIDER=local_hash
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
RAG_DENSE_WEIGHT=0.68
RAG_KEYWORD_WEIGHT=0.32
PGVECTOR_DSN=
PGVECTOR_TABLE=research_rag_chunks
ASSISTANT_TRACE_LIMIT=100
